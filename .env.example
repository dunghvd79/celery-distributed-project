# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
POSTGRES_DB=celerydb
POSTGRES_USER=celery
POSTGRES_PASS=celery123
POSTGRES_URL=postgresql://celery:celery123@localhost:5432/celerydb

# Celery
CELERY_BROKER_URL=amqp://admin:admin123@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Alerting (Giai đoạn 4 - điền vào sau)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERT_EMAIL=your-email@example.com
